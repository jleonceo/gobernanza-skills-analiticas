# Framework de Gobernanza de Skills Analíticas
# .gitignore - Archivos y carpetas a NO subir al repositorio

# =======================================================================
# DATOS SENSIBLES Y CONFIDENCIALES (NUNCA SUBIR)
# =======================================================================

# Archivos con datos reales de producción
*_REAL.md
*_REAL.json
*_PRODUCCION.*
*_CONFIDENCIAL.*
datos_reales/
produccion/
confidencial/

# Credenciales y configuraciones privadas
config_privada/
credentials/
*.env
.env.local
.env.production
secrets/
api_keys/

# Bases de datos con información real
*.db
*.sqlite
*.sql
backups_sql/
dumps/

# Archivos de Excel/CSV con datos empresariales
datos_clientes/
*_clientes.xlsx
*_clientes.csv
*_proveedores.*
*_facturas.*
*_nominas.*

# =======================================================================
# ARCHIVOS DEL SISTEMA OPERATIVO
# =======================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# =======================================================================
# ARCHIVOS TEMPORALES Y BACKUPS
# =======================================================================

# Archivos temporales
*.tmp
*.temp
*.bak
*.swp
*.swo
*~
~$*

# Backups de editores
*.orig
*.rej

# Carpetas temporales
temp/
tmp/
cache/

# =======================================================================
# EDITORES E IDEs
# =======================================================================

# Visual Studio Code
.vscode/
*.code-workspace

# JetBrains (IntelliJ, PyCharm, etc.)
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
Session.vim

# Emacs
*~
\#*\#
.\#*

